{
	"name": "my-monorepo",
	"private": true,
	"workspaces": [
		"apps/homepage",
		"apps/map"
	],
	"scripts": {
		"build": "bun run format && bun run --filter \"*\" build",
		"dev": "bun run format && bun run --filter \"*\" dev",
		"wc": "bun run format && bun run --filter \"*\" wc",
		"dev:homepage": "bun run format && bun run --filter homepage dev",
		"dev:map": "bun run format && bun run --filter map dev",
		"fm": "prettier --write . && oxfmt",
		"format:pretter": "prettier --write .",
		"fmt": "oxfmt",
		"fmt:check": "oxfmt --check",
		"lang": "bun x @inlang/cli machine translate --project ./project.inlang",
		"lang:val": "bun x @inlang/cli validate --project ./project.inlang",
		"lint": "oxlint .",
		"lint:fix": "oxlint --fix",
		"install:all": "bun install",
		"sp:fix": "syncpack fix",
		"sp:format": "syncpack format",
		"sp:lint": "syncpack lint --dependency-types prod,dev",
		"doctor": "svelte-doctor check"
	},
	"dependencies": {
		"swiper": "^12.1.4"
	},
	"devDependencies": {
		"@ianvs/prettier-plugin-sort-imports": "^4.7.1",
		"@prettier/plugin-oxc": "^0.1.4",
		"@types/bun": "^1.3.13",
		"@types/node": "^25.7.0",
		"concurrently": "^8.2.2",
		"oxc": "^1.0.1",
		"oxfmt": "^0.48.0",
		"oxlint": "^1.64.0",
		"prettier": "^3.8.3",
		"prettier-plugin-css-order": "^2.2.0",
		"prettier-plugin-organize-attributes": "^1.0.0",
		"prettier-plugin-svelte": "^3.5.2",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"typescript": "~6.0.3",
		"vite": "^8.0.12"
	}
}

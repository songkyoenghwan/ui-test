{
  "name": "my-monorepo",
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^25.7.0",
    "bun": "^1.3.13",
    "concurrently": "^8.2.2",
    "oxc": "^1.0.1",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.64.0",
    "prettier": "^3.8.3",
    "typescript": "~6.0.3",
    "vite": "^8.0.12",
    "prettier-plugin-css-order": "^2.2.0",
    "prettier-plugin-organize-attributes": "^1.0.0",
    "prettier-plugin-svelte": "^3.5.2",
    "prettier-plugin-tailwindcss": "^0.8.0"
  },
  "private": true,
  "scripts": {
    "build": "bun run --filter \"*\" build",
    "d": "concurrently \"bun run dev:homepage\" \"bun run dev:map\"",
    "dev": "concurrently \"bun run dev:homepage\" \"bun run dev:map\"",
    "dev:homepage": "bun run --filter homepage dev",
    "dev:map": "bun run --filter map dev",
    "format": "prettier --write .",
    "install:all": "bun install",
    "sp:fix": "syncpack fix",
    "sp:format": "syncpack format",
    "sp:lint": "syncpack lint --dependency-types prod,dev"
  },
  "workspaces": [
    "apps/homepage",
    "apps/map"
  ]
}

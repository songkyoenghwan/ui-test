{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"arrowParens": "always",
	"bracketSpacing": true,
	"htmlWhitespaceSensitivity": "ignore",
	"printWidth": 180,
	"singleQuote": true,
	"tabWidth": 4,
	"useTabs": true,
	"trailingComma": "all",
	"sortTailwindcss": {
		"preserveDuplicates": false
	},
	"cssDeclarationSorterOrder": "smacss",
	"sortPackageJson": true,
	"ignorePatterns": [
		"package-lock.json",
		"pnpm-lock.yaml",
		"yarn.lock",
		"dist/",
		"build/",
		"out/",
		".next/",
		".nuxt/",
		".cache/",
		".svelte-kit/",
		".astro/",
		"public/",
		"static/",
		"src/paraglide/",
		"message/",
		".vscode/",
		"**/*.ejs",
		"src/paraglide/",
		"project.inlang/settings.json",
		"wc/",
		".tsconfig.json",
		"src/styles/front-output.css",
		".oxlintrc.json",
		"pb/pb_data"
	]
}

{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"arrowParens": "always",
	"bracketSpacing": true,
	"cssDeclarationSorterOrder": "smacss",
	"htmlWhitespaceSensitivity": "ignore",
	"ignorePatterns": [
		"package-lock.json",
		"pnpm-lock.yaml",
		"yarn.lock",
		"node_modules/",
		"dist/",
		"build/",
		"out/",
		".next/",
		".nuxt/",
		".cache/",
		".svelte-kit/",
		".astro/",
		"*.min.*",
		"public/",
		"static/",
		"src/paraglide/",
		"message/",
		".vscode/",
		"**/*.ejs",
		"src/paraglide/",
		"wc/",
		".tsconfig.json",
		"src/styles/front-output.css",
		".oxlintrc.json",
		"pb/pb_data",
		"assets/js/deepfine/**/*.js",
		"assets/js/lib/*.js",
		"assets/js/lib/**/*.js",
		"assets/js/deepfine/**/*.map",
		"assets/js/*.min.js",
		"assets/js/bootstrap*.js",
		"assets/js/html2pdf*.js",
		"assets/js/jquery*.js",
		"assets/js/jstree.min.js",
		"assets/js/lc_lightbox.js",
		"assets/js/lightpick.js",
		"assets/js/popper.min.js",
		"assets/js/slick.min.js",
		"assets/js/swiper*.js"
	],
	"importOrderParserPlugins": ["typescript", "decorators-legacy"],
	"insertPragma": false,
	"jsxSingleQuote": false,
	"printWidth": 180,
	"proseWrap": "never",
	"quoteProps": "consistent",
	"requirePragma": false,
	"semi": true,
	"singleQuote": true,
	"sortPackageJson": false,
	"tabWidth": 4,
	"trailingComma": "all",
	"useTabs": true,
	"vueIndentScriptAndStyle": true
}

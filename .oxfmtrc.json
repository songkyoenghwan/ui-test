{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"arrowParens": "always",
	"bracketSpacing": true,
	"htmlWhitespaceSensitivity": "ignore",
	"printWidth": 180,
	"singleQuote": true,
	"tabWidth": 4,
	"useTabs": true,
	"trailingComma": "all",
	"sortTailwindcss": {
		"preserveDuplicates": false
	},
	"cssDeclarationSorterOrder": "smacss",
	"sortPackageJson": true,
	"sortImports": {
		"groups": [
			"builtin", // 1. 노드 순정 내장 모듈 (fs, path 등)
			"external", // 2. npm 외부 라이브러리 본진 (svelte, swiper, animejs 등 통치)
			"internal", // 3. 내부 프로젝트 모듈 ($lib 가상 경로 자동 매싱)
			["parent", "sibling", "index"] // 4. 상대 경로 (../, ./) 모음
		]
	},
	"ignorePatterns": [
		"**/messages/*.json",
		"**/message/*.json",
		"**/.svelte-doctor/**",
		"package-lock.json",
		"pnpm-lock.yaml",
		"yarn.lock",
		"dist/",
		"build/",
		"output/",
		"out/",
		".next/",
		".nuxt/",
		".cache/",
		".svelte-kit/",
		".astro/",
		"public/",
		"static/",
		"src/paraglide/",
		".vscode/",
		"**/*.ejs",
		"project.inlang/settings.json",
		"wc/",
		".tsconfig.json",
		"src/styles/front-output.css",
		".oxlintrc.json",
		"pb/pb_data"
	]
}

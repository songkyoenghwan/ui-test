{
	"name": "ui",
	"version": "0.0.0",
	"dependencies": {
		"lit": "^3.3.2",
		"svelte": "^5.55.5"
	},
	"devDependencies": {
		"@sveltejs/enhanced-img": "^0.10.4",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@trivago/prettier-plugin-sort-imports": "^6.0.2",
		"@tsconfig/svelte": "^5.0.8",
		"@types/node": "^25.7.0",
		"oxc": "^1.0.1",
		"oxfmt": "^0.48.0",
		"oxlint": "^1.63.0",
		"prettier": "^3.8.3",
		"prettier-plugin-css-order": "^2.2.0",
		"prettier-plugin-organize-attributes": "^1.0.0",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte-check": "^4.4.8",
		"tailwindcss": "^4.3.0",
		"typescript": "~6.0.2",
		"vite": "^8.0.10"
	},
	"private": true,
	"scripts": {
		"build": "tsc && vite build",
		"dev": "vite dev --host --port 7713",
		"fmt": "oxfmt",
		"fmt:check": "oxfmt --check",
		"format": "prettier --write .",
		"lint": "oxlint .",
		"prepare": "svelte-kit sync || echo ''",
		"preview": "concurrently \"vite preview --host\"",
		"sp:fix": "syncpack fix",
		"sp:format": "syncpack format",
		"sp:lint": "syncpack lint --dependency-types prod,dev",
		"wc": "bun -b run vite build -c vite.config.sv.mjs"
	},
	"type": "module"
}
